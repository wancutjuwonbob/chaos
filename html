                desc: '원하는 주제나 텍스트 대본 핵심 요약본을 피딩하면 전용 AI 알고리즘이 슬라이드 레이아웃 컴포넌트 구조, 매칭 스톡 이미지, 서식 스타일링을 단 10초 만에 인라인 구축하는 고속 빌더입니다.'
            },
            {
                id: 'notebooklm',
                name: 'Google NotebookLM',
                category: '폐쇄형 소스 기반 전공 서적 및 PDF 집중 학습기',
                url: 'https://notebooklm.google',
                scores: { speed: 3, accuracy: 5, creativity: 2, korean: 5, cost: 5 },
                caveat: '철저히 사용자가 마운트해 준 업로드 소스 풀(Pool) 내부 정보만 연산하므로, 소스 자체에 에러나 정보 누락이 있을 경우 전체 분석 무결성이 붕괴됨.',
                desc: '교수님 강의록, 녹음 타이핑 스크립트, 두꺼운 전공 PDF를 전용 가상 공간에 하이딩하여 환각율을 0%에 수렴시킨 나만의 튜터 구축기입니다. AI 기반 다자간 대화 요약 팟캐스트 변환 기능을 포함합니다.'
            },
            {
                id: 'beautifulai',
                name: 'Beautiful.ai',
                category: '수치 기반 데이터 인포그래픽 슬라이드 툴',
                url: 'https://www.beautiful.ai',
                scores: { speed: 3, accuracy: 4, creativity: 3, korean: 3, cost: 2 },
                caveat: '무료 크레딧 체험 조건이 엄격하고 영문 인터페이스 기반이므로 한글 타이포그래피 정렬 유실 여부를 상시 수동 트래킹해야 함.',
                desc: '통계 수치나 정렬 규칙 변수 값을 수정하는 즉시 인라인 다이어그램, 타임라인 그리드가 수학적 디자인 그리드 법칙에 맞추어 유기적으로 가변 이동 변형되는 정밀 수치 프레젠테이션 엔진입니다.'
            },
            {
                id: 'cursor',
                name: 'Cursor AI 코드 에디터',
                category: 'AI 네이티브 소프트웨어 프로그래밍 구현 환경',
                url: 'https://www.cursor.com',
                scores: { speed: 5, accuracy: 4, creativity: 3, korean: 3, cost: 4 },
                caveat: '컨텍스트 윈도우 스팬 설계의 한계로 인해 대형 소스코드 베이스 추론 시 엉뚱한 로직 코드를 제안할 가능성이 상시 존재하여 상시 컴파일 체크 필요.',
                desc: 'VS Code 플랫폼 코어를 그대로 계승한 상태에서 파일 간의 상관관계를 다차원 추적하여 코드 전체 설계, 빌드 에러 추적, 디버깅 자동 수정을 자연어 대화로 처리하는 공학 프로그래밍 필수 환경입니다.'
            }
        ];

        // 2. 가중치 보정 연산 테이블 세팅 (Scenario Constraints Modifiers Mapping)
        const scenarioMatrix = {
            deadline: {
                name: '🚨 내일 아침까지 제출 (마감 임박)',
                bias: { speed: 2.5, accuracy: 0, creativity: 0.5, korean: 1.0, cost: 0 }
            },
            academic: {
                name: '📚 전공 논문 및 리포트 (정확도 우선)',
                bias: { speed: -1.0, accuracy: 3.0, creativity: -1.0, korean: 1.5, cost: 0.5 }
            },
            brainstorm: {
                name: '💡 팀플 기획 및 창의적 아이디어 도출',
                bias: { speed: 0, accuracy: -0.5, creativity: 2.5, korean: 1.0, cost: 0 }
            },
            coding: {
                name: '💻 프로그래밍 및 알고리즘 구현 과제',
                bias: { speed: 1.0, accuracy: 2.0, creativity: 0.5, korean: 0, cost: 0.5 }
            }
        };

        // 전역 차트 인스턴스 홀더 변수 (메모리 릭 및 캔버스 재사용 버그 블로킹용)
        window.myRadarChart = null;

        // 3. UI 슬라이더 동적 인디케이터 바인딩 함수
        function updateSliderValue(metric) {
            const slider = document.getElementById(`slider-${metric}`);
            const text = document.getElementById(`val-${metric}`);
            text.innerText = slider.value;
        }

        // 4. 의사결정 수리 알고리즘 계산 엔진 구현 코어 (Core Decision Engine)
        function calculateRecommendation() {
            // UI로부터 원시 입력값 바인딩 파싱
            const selectedScenario = document.querySelector('input[name="scenario"]:checked').value;
            const uSpeed = parseInt(document.getElementById('slider-speed').value);
            const uAccuracy = parseInt(document.getElementById('slider-accuracy').value);
            const uCreativity = parseInt(document.getElementById('slider-creativity').value);
            const uKorean = parseInt(document.getElementById('slider-korean').value);
            const uCost = parseInt(document.getElementById('slider-cost').value);

            const matrix = scenarioMatrix[selectedScenario];
            
            // 공학적 벡터 가중치 변형 연산 (입력치 + 시나리오 가중 편향 결합 알고리즘)
            const finalWeights = {
                speed: Math.max(0.5, uSpeed + matrix.bias.speed),
                accuracy: Math.max(0.5, uAccuracy + matrix.bias.accuracy),
                creativity: Math.max(0.5, uCreativity + matrix.bias.creativity),
                korean: Math.max(0.5, uKorean + matrix.bias.korean),
                cost: Math.max(0.5, uCost + matrix.bias.cost)
            };

            // 가중치 모델 매트릭스 도출 처리 루프 (Weighted Scoring Formula)
            const evaluatedTools = aiToolsDataset.map(tool => {
                let compositeScore = 0;
                compositeScore += tool.scores.speed * finalWeights.speed;
                compositeScore += tool.scores.accuracy * finalWeights.accuracy;
                compositeScore += tool.scores.creativity * finalWeights.creativity;
                compositeScore += tool.scores.korean * finalWeights.korean;
                compositeScore += tool.scores.cost * finalWeights.cost;

                // 특정 예외 상황 컨텍스트 타겟 도구 보정용 인센티브 상향 오버라이드
                if (selectedScenario === 'coding' && tool.id === 'cursor') compositeScore += 8.0;
                if (selectedScenario === 'deadline' && tool.id === 'gamma') compositeScore += 6.0;
                if (selectedScenario === 'academic' && tool.id === 'notebooklm') compositeScore += 5.0;

                return { ...tool, calculatedScore: compositeScore };
            });

            // 스코어 순 정렬 (Descending Sort)
            evaluatedTools.sort((a, b) => b.calculatedScore - a.calculatedScore);

            const topSolution = evaluatedTools[0];
            const alternatives = evaluatedTools.slice(1, 3); // 2등, 3등 추출

            // 결과 보드 마운트 가시화 트랜지션 처리
            document.getElementById('result-placeholder').classList.add('hidden');
            
            // DOM 바인딩 주입
            document.getElementById('res-scenario-tag').innerText = `매칭 가이던스: ${matrix.name}`;
            document.getElementById('res-tool-name').innerText = topSolution.name;
            document.getElementById('res-tool-cat').innerText = topSolution.category;
            document.getElementById('res-tool-link').href = topSolution.url;
            document.getElementById('res-tool-desc').innerText = topSolution.desc;
            document.getElementById('res-tool-caveat').innerText = topSolution.caveat;

            // XAI 동적 자연어 문장 빌드 생성기 작동
            document.getElementById('res-xai-text').innerHTML = generateXAIEvidence(topSolution, finalWeights, matrix.name);

            // 차순위 대안 아키텍처 노드 렌더링
            renderAlternativeCards(alternatives);

            // 차트 가시화 렌더러 파이프라인 가동
            renderRadarVisualizer(topSolution.scores);
        }

        // 5. 설명 가능한 AI (XAI) 구문 조합 엔진 파서
        function generateXAIEvidence(tool, weights, scenarioName) {
            // 가장 높게 산출된 타겟 가중치 영역을 소팅 판정
            let maxMetric = 'speed';
            let maxVal = weights.speed;
            for (const [key, value] of Object.entries(weights)) {
                if (value > maxVal) {
                    maxVal = value;
                    maxMetric = key;
                }
            }

            const metricKo = {
                speed: '초고속 생성 및 속도전',
                accuracy: '데이터 무결성 및 엄격한 정확도',
                creativity: '창의적이고 구조화된 기획력',
                korean: '매끄러운 한글 문맥 최적화 품질',
                cost: '비용 효율성 및 리소스 한도 프리 레이시오'
            };

            return `당신이 세팅하신 <strong>[${scenarioName}]</strong> 상황의 요구 필터 조건과 내부 벡터 연산상 가중 비중이 가장 높게 투영된 지표인 <strong>'${metricKo[maxMetric]}' (가중치 지표치: ${maxVal.toFixed(1)})</strong> 조합을 종합 추적 연산한 결과, 해당 성능 지표에서 절대 평점 합산 <strong>최대 임계점</strong>을 기록한 <strong>${tool.name}</strong> 아키텍처가 최적의 매칭 매커니즘을 증명하여 의사결정 결과로 도출되었습니다.`;
        }

        // 6. 차순위 대안 솔루션 동적 DOM 생성 렌더러
        function renderAlternativeCards(alternatives) {
            const container = document.getElementById('runner-ups-container');
            container.innerHTML = ''; // 초기화

            alternatives.forEach(alt => {
                const card = document.createElement('div');
                card.className = "bg-slate-50 border border-slate-200 rounded-lg p-3 flex flex-col justify-between hover:bg-slate-100/70 transition-colors";
                card.innerHTML = `
                    <div>
                        <div class="flex justify-between items-start">
                            <h4 class="text-xs font-bold text-slate-800">${alt.name}</h4>
                            <span class="text-[9px] font-semibold text-slate-400 bg-white px-1.5 py-0.5 rounded border border-slate-200">대안 매칭</span>
                        </div>
                        <p class="text-[11px] text-slate-500 mt-1 line-clamp-2 leading-relaxed">${alt.desc}</p>
                    </div>
                    <div class="flex items-center justify-between mt-2.5 pt-2 border-t border-slate-200/60">
                        <span class="text-[10px] text-indigo-600 font-medium">${alt.category.split(' ')[0]}...</span>
                        <a href="${alt.url}" target="_blank" class="text-[10px] font-bold text-slate-900 hover:underline">이동 ↗</a>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        // 7. Chart.js 동적 드로잉 제어 파이프라인 (Radar Chart Engine)
        function renderRadarVisualizer(scores) {
            const ctx = document.getElementById('radarChart').getContext('2d');
            
            // 기존 가동 중인 차트 백그라운드 인스턴스 메모리 클리어 소멸 파괴 처리
            if (window.myRadarChart !== null) {
                window.myRadarChart.destroy();
            }

            window.myRadarChart = new Chart(ctx, {
                type: 'radar',
                data: {
                    labels: ['속도', '정확도', '창의성', '한국어', '비용효율'],
                    datasets: [{
                        label: '도구 고유 성능 프로필',
                        data: [scores.speed, scores.accuracy, scores.creativity, scores.korean, scores.cost],
                        backgroundColor: 'rgba(79, 70, 229, 0.15)',
                        borderColor: 'rgba(79, 70, 229, 1)',
                        borderWidth: 1.5,
                        pointBackgroundColor: 'rgba(79, 70, 229, 1)',
                        pointRadius: 2.5
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false } // 공간 협소로 인한 생략
                    },
                    scales: {
                        r: {
                            min: 0,
                            max: 5,
                            ticks: { stepSize: 1, display: false },
                            grid: { color: 'rgba(0, 0, 0, 0.05)' },
                            angleLines: { color: 'rgba(0, 0, 0, 0.05)' },
                            pointLabels: { font: { size: 10, weight: '500' } }
                        }
                    }
                }
            });
        }

        // 8. 피드백 루프 데이터 모킹 수집 함수 (Feedback Loop)
        function submitSatisfaction(type) {
            const zone = document.getElementById('feedback-interactive-zone');
            if(type === 'positive') {
                zone.innerHTML = `<div class="w-full text-center py-2 text-xs font-semibold text-emerald-700 bg-emerald-50 rounded-lg border border-emerald-100">🌿 피드백 축적 완료: 긍정 데이터가 알고리즘 정밀도 가중치 튜닝 세션에 전송되었습니다. 감사합니다!</div>`;
            } else {
                zone.innerHTML = `<div class="w-full text-center py-2 text-xs font-semibold text-amber-700 bg-amber-50 rounded-lg border border-amber-100">⚠️ 피드백 축적 완료: 매칭 어긋남 오류 기록이 아키텍처 예외 교정 데이터셋에 반영되었습니다.</div>`;
            }
        }

        function submitToolReport() {
            const input = document.getElementById('report-tool-input');
            if(!input.value.trim()) {
                alert('도구 이름을 올바르게 입력해 주세요.');
                return;
            }
            alert(`[제보 성공] 검증 요청 파일럿 필드에 '${input.value}' 도구가 등록되었습니다. 2026 데이터 패치 시 정밀 분석 후 반영됩니다.`);
            input.value = '';
        }
    </script>
